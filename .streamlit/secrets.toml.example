# .streamlit/secrets.toml のテンプレ。本番用の値はコミットせず Streamlit Cloud の
# Settings → Secrets に貼る。ローカル開発用は .streamlit/secrets.toml にコピーして
# 本物の値を埋める（.gitignore で除外済み）。

# ── Google 自己登録ログイン（st.login） ───────────────────────────────
# Streamlit 1.42+ の st.login() が読む標準セクション。Google OAuth 2.0 を使う。
[auth]
# ローカル開発時は http://localhost:8501/oauth2callback
# 本番は https://<your-app>.streamlit.app/oauth2callback に差し替える
redirect_uri = "http://localhost:8501/oauth2callback"
# セッションクッキー署名用。予測不能な32バイト以上のランダム文字列を必ず入れる。
# 生成例:
#   python -c "import secrets; print(secrets.token_hex(32))"
cookie_secret = "REPLACE_ME_WITH_A_LONG_RANDOM_STRING"
# Google Cloud Console → OAuth 2.0 クライアント ID の「クライアントID / シークレット」
client_id = "xxxxxxxxxxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# ── Cloudflare KV（ユーザー別ポートフォリオの端末間同期） ───────────
# cloud_store.py が参照。ログインで得た email をハッシュ化してキーにする。
[cloudflare]
account_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
kv_namespace_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
api_token = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# 全員1個のバケツで運用（自分専用）の時のみ true。通常は未指定/false。
# solo_mode = false
